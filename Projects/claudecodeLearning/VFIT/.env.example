# ============================================
# CLIENT-SIDE (bundled into browser — safe to expose)
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# SERVER-ONLY (used by /api serverless functions — NEVER prefix with VITE_)
# These keys are NEVER sent to the browser.
# ============================================
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key
GEMINI_API_KEY=your-gemini-api-key

# ============================================
# FIREBASE (Optional — client-side, public by design)
# ============================================
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_VAPID_KEY=your-vapid-key
